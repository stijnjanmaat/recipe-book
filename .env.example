# Database - PostgreSQL
# For local development, use the connection string for the Docker Compose Postgres instance
DATABASE_URL="postgresql://recipebook:recipebook@localhost:5433/recipebook"

# For production (Vercel Postgres), uncomment and use:
# DATABASE_URL="postgresql://..."
# POSTGRES_URL="postgresql://..."
# POSTGRES_PRISMA_URL="postgresql://..."
# POSTGRES_URL_NON_POOLING="postgresql://..."

# AI/LLM - OpenAI
OPENAI_API_KEY="sk-..."
AI_MODEL="gpt-4o"  # For image extraction (supports vision)
AI_MODEL_TEXT="gpt-4o"  # For URL extraction

# Storage - Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# App
NODE_ENV="development"
