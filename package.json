  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc && vite build",
    "build:prod": "pnpm db:migrate && pnpm build",
    "preview": "vite preview",
    "start": "vite",
    "tsr:generate": "tsr generate",
    "vercel": "/Users/stijnjanmaat/Library/pnpm/vercel",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "db:reset": "drizzle-kit drop && drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "icons:generate": "node scripts/generate-icons.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
